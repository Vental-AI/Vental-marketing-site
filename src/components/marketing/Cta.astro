---
import { ArrowRightIcon } from "lucide-react"
---

<section id="cta" class="border-b border-border">
  <div class="mx-auto max-w-[1200px] px-6 py-24 md:py-32">
    <div
      class="relative overflow-hidden rounded-3xl border border-border bg-card px-6 py-16 sm:px-12 md:py-24"
    >
      <div
        aria-hidden
        class="absolute inset-x-0 -top-32 -z-10 h-[420px] bg-[radial-gradient(ellipse_60%_60%_at_50%_30%,oklch(from_var(--primary)_l_c_h_/_0.12),transparent_70%)]"
      >
      </div>

      <div
        class="mx-auto flex max-w-2xl flex-col items-center gap-6 text-center"
      >
        <h2
          class="text-3xl font-semibold tracking-tight text-balance sm:text-4xl md:text-5xl"
        >
          Bring the rigor of an appraisal to every estimate.
        </h2>
        <p class="text-pretty text-muted-foreground">
          See Vental in action with a 20-minute walkthrough.
        </p>
        <div class="mt-2 flex justify-center">
          <a
            href="mailto:hello@vental.ai"
            class="inline-flex h-10 items-center gap-2 rounded-4xl bg-primary px-5 text-sm font-medium text-primary-foreground transition-colors hover:bg-primary/80"
          >
            Book a demo
            <ArrowRightIcon className="size-4" />
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
