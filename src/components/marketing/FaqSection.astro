---
import { Faq } from "@/components/marketing/Faq"
---

<section id="faq" class="border-b border-border bg-muted/30">
  <div class="mx-auto max-w-[1200px] px-6 py-24 md:py-32">
    <div class="grid gap-12 lg:grid-cols-[1fr_2fr]">
      <div class="flex flex-col gap-4">
        <p
          class="text-xs font-medium tracking-widest text-muted-foreground uppercase"
        >
          FAQ
        </p>
        <h2
          class="text-3xl font-semibold tracking-tight text-balance sm:text-4xl"
        >
          Answers, before you ask.
        </h2>
        <p class="text-sm text-muted-foreground">
          Still have questions? <a
            href="#cta"
            class="font-medium text-foreground underline-offset-4 hover:underline">Get in touch</a
          >.
        </p>
      </div>
      <Faq client:load />
    </div>
  </div>
</section>
